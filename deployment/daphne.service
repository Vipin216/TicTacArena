[Unit]
Description=Daphne Server
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/TicTacArena
Environment="DJANGO_SETTINGS_MODULE=config.settings"
ExecStart=/home/ubuntu/TicTacArena/venv/bin/daphne -b 0.0.0.0 -p 8001 config.asgi:application
Restart=always

[Install]
WantedBy=multi-user.target